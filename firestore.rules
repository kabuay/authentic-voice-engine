rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /personas/{personaId} {
      // Anyone can read personas (required for unauthenticated guests to see the list)
      allow read: if true;
      
      // ONLY authenticated Google SSO users can create, update, or delete actual personas.
      allow create, update, delete: if request.auth != null;
    }
  }
}
